generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model League {
  id            Int            @id @default(autoincrement())
  apiFootballId Int            @unique
  name          String
  country       String
  logoUrl       String?
  matches       Match[]
  standings     TeamStanding[]
}

model Stadium {
  id             Int     @id @default(autoincrement())
  name           String
  city           String
  cityNormalized String
  timezone       String
  googleMapsUrl  String?
  matches        Match[]

  // Transport fields (Phase 15) — populated per-stadium by admin via CSV/SQL
  nearbyMetros          String[]   // e.g. ["Line 1 - Stade de France", "RER D"]
  nearbyTrains          String[]   // e.g. ["RER B - Paris Nord"]
  nearbyBuses           String[]   // e.g. ["Bus 154", "Bus 255"]
  walkingTimeFromCenter String?    // e.g. "25 min walk from Gare du Nord"
  publicTransportInfo   String?    // Free-text general transport tip
  parkingInfo           String?    // Free-text parking notes

  // Coordinates (Phase 19) — WGS-84 decimal degrees, null until populated via CSV/SQL
  latitude  Float?   // WGS-84 decimal degrees — null until populated via CSV/SQL
  longitude Float?   // WGS-84 decimal degrees — null until populated via CSV/SQL

  @@index([cityNormalized])
  @@index([name])
}

model Team {
  id                Int            @id @default(autoincrement())
  apiFootballId     Int            @unique
  name              String
  logoUrl           String?
  awayMatches       Match[]        @relation("AwayTeam")
  homeMatches       Match[]        @relation("HomeTeam")
  posts             Post[]
  standings         TeamStanding[]
  usersWithFavorite User[]         @relation("FavoriteClub")
  favoritedBy       UserFavorite[]
}

model Match {
  id            Int      @id @default(autoincrement())
  apiFootballId Int      @unique
  leagueId      Int
  homeTeamId    Int
  awayTeamId    Int
  stadiumId     Int?
  matchDate     DateTime
  status        String   @default("NS")
  ticketUrl     String?
  awayTeam      Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam      Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  league        League   @relation(fields: [leagueId], references: [id])
  stadium       Stadium? @relation(fields: [stadiumId], references: [id])

  @@index([matchDate])
}

model TeamStanding {
  id           Int    @id @default(autoincrement())
  teamId       Int
  leagueId     Int
  season       Int
  position     Int
  played       Int
  wins         Int
  draws        Int
  losses       Int
  goalsFor     Int
  goalsAgainst Int
  points       Int
  league       League @relation(fields: [leagueId], references: [id])
  team         Team   @relation(fields: [teamId], references: [id])

  @@unique([teamId, leagueId, season])
  @@index([teamId])
}

model User {
  id             Int            @id @default(autoincrement())
  email          String         @unique
  name           String
  passwordHash   String?
  createdAt      DateTime       @default(now())
  age            Int?
  favoriteClubId Int?
  googleId       String?        @unique
  avatarUrl      String?
  country        String?
  posts          Post[]
  upvotes        Upvote[]
  favoriteClub   Team?          @relation("FavoriteClub", fields: [favoriteClubId], references: [id])
  favorites      UserFavorite[]
}

model Post {
  id          Int      @id @default(autoincrement())
  teamId      Int
  userId      Int?
  postType    PostType
  title       String
  body        String
  authorName  String
  authorEmail String
  photoUrl    String?
  seatSection String?
  seatRow     String?
  seatNumber  String?
  seatRating  Int?
  pubName     String?
  pubAddress  String?
  pubDistance String?
  matchId     Int?
  upvoteCount Int      @default(0)
  reported    Boolean  @default(false)
  createdAt   DateTime @default(now())
  team        Team     @relation(fields: [teamId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
  upvotes     Upvote[]

  // Transport tip fields (Phase 15) — only populated when postType = GETTING_THERE
  transportType String?   // "Metro" | "Bus" | "Train" | "Taxi" | "Walking" | "Other"
  travelCost    String?   // e.g. "€1.90 per trip"
  travelTime    String?   // e.g. "20 min from city centre"

  @@index([teamId])
  @@index([postType])
}

model Upvote {
  id     Int  @id @default(autoincrement())
  postId Int
  userId Int
  post   Post @relation(fields: [postId], references: [id])
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model UserFavorite {
  id     Int  @id @default(autoincrement())
  userId Int
  teamId Int
  team   Team @relation(fields: [teamId], references: [id])
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

enum PostType {
  GENERAL_TIP
  SEAT_TIP
  PUB_RECOMMENDATION
  IM_GOING
  GETTING_THERE   // Added in Phase 15 for community transport tips
}
