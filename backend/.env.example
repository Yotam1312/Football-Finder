# Database (Azure PostgreSQL)
# Must include ?connection_limit=5 for Azure basic tier
DATABASE_URL="postgresql://user:password@host:5432/football_finder?connection_limit=5"

# API-Football
# Get your key from api-football.com
API_FOOTBALL_KEY="your_key_here"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (used for CORS — no trailing slash)
FRONTEND_URL="http://localhost:5173"

# Azure Blob Storage (used for photo uploads in Phase 10)
# Get connection string from: Azure Portal -> Storage Account -> Access keys -> Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# Create a container with access level "Blob (anonymous read for blobs only)"
AZURE_STORAGE_CONTAINER_NAME=football-finder-uploads
